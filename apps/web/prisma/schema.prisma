generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MediaType {
  MOVIE
  TV_SERIES
  UNKNOWN
}

enum ParseStatus {
  PENDING
  PARSED
  FAILED
}

enum ParsedReleaseMatchStatus {
  MATCHED
  UNMATCHED
  REJECTED
}

enum ParsedReleaseMatchSource {
  AUTO
  MANUAL
}

enum MediaTitleProviderLinkSource {
  MANUAL
  PROVIDER_CROSSREF
  SEARCH_MATCH
  IMPORT
}

enum MediaProviderIdentityLinkSource {
  MANUAL
  PROVIDER_CROSSREF
  SEARCH_MATCH
  IMPORT
}

enum ProviderRatingType {
  USER_SCORE
  CRITIC_SCORE
  POPULARITY
}

enum DownloaderType {
  QBITTORRENT
  TRANSMISSION
}

enum DownloadStatus {
  QUEUED
  SENDING
  SENT
  DOWNLOADING
  COMPLETE
  FAILED
  SKIPPED
}

enum DownloadSource {
  MANUAL
  SUBSCRIPTION
  RETRY
}

enum DedupeKeyType {
  INFO_HASH
  RELEASE_SIGNATURE
  LINK_HASH
}

model Tenant {
  id                   String                      @id @default(cuid())
  name                 String
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  settings             TenantSettings?
  providerConfigs      TenantProviderConfig[]
  providerPolicies     TenantMediaProviderPolicy[]
  providerSourceConfigs TenantProviderSourceConfig[]
  providerSourcePolicies TenantProviderSourcePolicy[]
  memberships          TenantMembership[]
  feeds                RssFeed[]
  items                RssItem[]
  parsedReleases       ParsedRelease[]
  parsedReleaseMatches ParsedReleaseMatch[]
  downloaders          Downloader[]
  subscriptions        Subscription[]
  subscriptionRules    SubscriptionRule[]
  matchDecisions       SubscriptionMatchDecision[]
  downloadJobs         DownloadJob[]
  audits               AuditLog[]
}

model TenantSettings {
  tenantId            String @id
  defaultDownloaderId String?
  webLanguage         String @default("en-US")
  tenant              Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([defaultDownloaderId])
}

model TenantProviderConfig {
  id                   String    @id @default(cuid())
  tenantId             String
  provider             String
  enabled              Boolean   @default(true)
  encryptedSecretsJson String?   @db.Text
  configuredAt         DateTime?
  lastValidatedAt      DateTime?
  lastError            String?
  metadataLanguage     String?
  region               String?
  baseUrl              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model TenantMediaProviderPolicy {
  id                       String    @id @default(cuid())
  tenantId                 String
  mediaType                MediaType
  provider                 String
  enabledForMatching       Boolean   @default(true)
  enabledForPresentation   Boolean   @default(true)
  matchingPriority         Int
  presentationPriority     Int
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  tenant                   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, mediaType, provider])
  @@index([tenantId, mediaType])
}

model TenantProviderSourceConfig {
  id                   String    @id @default(cuid())
  tenantId             String
  providerSource       String
  enabled              Boolean   @default(true)
  encryptedSecretsJson String?   @db.Text
  configuredAt         DateTime?
  lastValidatedAt      DateTime?
  lastError            String?
  metadataLanguage     String?
  region               String?
  baseUrl              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, providerSource])
  @@index([tenantId])
}

model TenantProviderSourcePolicy {
  id                       String    @id @default(cuid())
  tenantId                 String
  mediaType                MediaType
  providerSource           String
  enabledForMatching       Boolean   @default(true)
  enabledForPresentation   Boolean   @default(true)
  matchingPriority         Int
  presentationPriority     Int
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  tenant                   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, mediaType, providerSource])
  @@index([tenantId, mediaType])
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  name                 String
  passwordHash         String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  memberships          TenantMembership[]
  createdFeeds         RssFeed[]          @relation("FeedCreator")
  createdDownloaders   Downloader[]       @relation("DownloaderCreator")
  createdSubscriptions Subscription[]     @relation("SubscriptionCreator")
  createdDownloadJobs  DownloadJob[]      @relation("DownloadJobCreator")
  audits               AuditLog[]
}

model TenantMembership {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole @default(MEMBER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

model RssFeed {
  id                          String    @id @default(cuid())
  tenantId                    String
  createdByUserId             String
  name                        String
  encryptedUrl                String?   @db.Text
  urlHash                     String?
  encryptedRequestHeadersJson String?   @db.Text
  pollIntervalSeconds         Int       @default(600)
  enabled                     Boolean   @default(true)
  lastPolledAt                DateTime?
  lastError                   String?
  deletedAt                   DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  tenant                      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy                   User      @relation("FeedCreator", fields: [createdByUserId], references: [id])
  items                       RssItem[]

  @@unique([id, tenantId])
  @@index([tenantId, enabled])
  @@index([tenantId, createdAt])
  @@index([urlHash])
}

model RssItem {
  id                  String                      @id @default(cuid())
  tenantId            String
  feedId              String
  infoHash            String?
  guidHash            String?
  linkHash            String?
  dedupeKeyType       DedupeKeyType
  dedupeKeyHash       String
  releaseSignature    String?
  rawTitle            String
  encryptedTorrentUrl String                      @db.Text
  encryptedSourceUrl  String?                     @db.Text
  publishDate         DateTime?
  sizeBytes           BigInt?
  rawJsonEncrypted    String?                     @db.Text
  rawJsonRedacted     Json?
  parseStatus         ParseStatus                 @default(PENDING)
  parseConfidence     Float                       @default(0)
  firstSeenAt         DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  feed                RssFeed                     @relation(fields: [feedId, tenantId], references: [id, tenantId], onDelete: Cascade)
  parsedRelease       ParsedRelease?
  matchDecisions      SubscriptionMatchDecision[]
  downloadJobs        DownloadJob[]

  @@unique([id, tenantId])
  @@unique([feedId, dedupeKeyType, dedupeKeyHash])
  @@index([tenantId, firstSeenAt])
  @@index([tenantId, parseStatus])
  @@index([tenantId, releaseSignature])
  @@index([tenantId, infoHash])
}

model ParsedRelease {
  id              String               @id @default(cuid())
  tenantId        String
  rssItemId       String
  title           String
  providerSearchTitles String[]             @default([])
  year            Int?
  mediaType       MediaType            @default(UNKNOWN)
  season          Int?
  episode         Int?
  episodeEnd      Int?
  resolution      Int?
  quality         String?
  source          String?
  codec           String?
  audio           String?
  releaseGroup    String?
  parseConfidence Float                @default(0)
  parsedAt        DateTime             @default(now())
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item            RssItem              @relation(fields: [rssItemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  matches         ParsedReleaseMatch[]

  @@unique([rssItemId, tenantId])
  @@unique([id, tenantId])
  @@index([tenantId, mediaType, year])
  @@index([tenantId, title])
}

model MediaTitle {
  id             String    @id @default(cuid())
  supersededById String?
  mediaType      MediaType
  title          String    @map("canonicalTitle")
  titleKey       String    @map("normalizedTitle")
  originalTitle  String?
  releaseYear    Int?
  endYear        Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supersededBy       MediaTitle?               @relation("MediaTitleSupersession", fields: [supersededById], references: [id], onDelete: Restrict)
  supersedes         MediaTitle[]              @relation("MediaTitleSupersession")
  providerIdentities MediaProviderIdentity[]
  providerLinks      MediaTitleProviderLink[]
  releaseMatches     ParsedReleaseMatch[]
  subscriptions      Subscription[]
  sourceMerges       MediaTitleMerge[]         @relation("MediaTitleMergeSource")
  targetMerges       MediaTitleMerge[]         @relation("MediaTitleMergeTarget")

  @@unique([id, mediaType])
  @@index([mediaType, titleKey])
  @@index([supersededById])
}

model MediaTitleMerge {
  id                 String     @id @default(cuid())
  sourceMediaTitleId String
  targetMediaTitleId String
  reason             String
  evidenceJson       Json?
  mergedAt           DateTime   @default(now())
  mergedBy           String?
  algorithmVersion   String?
  sourceMediaTitle   MediaTitle @relation("MediaTitleMergeSource", fields: [sourceMediaTitleId], references: [id], onDelete: Restrict)
  targetMediaTitle   MediaTitle @relation("MediaTitleMergeTarget", fields: [targetMediaTitleId], references: [id], onDelete: Restrict)

  @@unique([sourceMediaTitleId, targetMediaTitleId])
  @@index([targetMediaTitleId])
}

model MediaProviderIdentity {
  id             String                          @id @default(cuid())
  mediaTitleId   String
  provider       String
  providerId     String
  mediaType      MediaType
  linkConfidence Float
  linkSource     MediaProviderIdentityLinkSource
  confirmedAt    DateTime
  createdAt      DateTime                        @default(now())
  updatedAt      DateTime                        @updatedAt

  mediaTitle     MediaTitle              @relation(fields: [mediaTitleId], references: [id], onDelete: Cascade)
  metadata       ProviderMediaMetadata[]
  releaseMatches ParsedReleaseMatch[]

  @@unique([provider, providerId, mediaType])
  @@index([mediaTitleId])
  @@index([provider, mediaType])
}

model ProviderMediaMetadata {
  id                      String              @id @default(cuid())
  mediaProviderIdentityId String
  providerSource          String
  localeKey               String
  title                   String
  originalTitle           String?
  titleAliases            String[]            @default([])
  titleKey                String
  releaseYear             Int?
  endYear                 Int?
  payload                 Json
  payloadHash             String
  ratingValue             Float?
  ratingScale             Float?
  ratingVoteCount         Int?
  ratingType              ProviderRatingType?
  fetchedAt               DateTime            @default(now())
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  mediaProviderIdentity MediaProviderIdentity @relation(fields: [mediaProviderIdentityId], references: [id], onDelete: Cascade)
  releaseMatches        ParsedReleaseMatch[]

  @@unique([mediaProviderIdentityId, providerSource, localeKey])
  @@index([providerSource, titleKey, releaseYear])
  @@index([mediaProviderIdentityId])
}

model ProviderTitle {
  id                 String              @id @default(cuid())
  provider           String
  providerEntityType String
  providerId         String
  mediaType          MediaType
  title              String
  normalizedTitle    String
  originalTitle      String?
  releaseYear        Int?
  endYear            Int?
  language           String?
  region             String?
  payload            Json
  payloadHash        String
  ratingValue        Float?
  ratingScale        Float?
  ratingVoteCount    Int?
  ratingType         ProviderRatingType?
  fetchedAt          DateTime            @default(now())
  expiresAt          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  mediaTitleLink MediaTitleProviderLink?
  releaseMatches ParsedReleaseMatch[]

  @@unique([provider, providerEntityType, providerId])
  @@unique([id, mediaType])
  @@index([provider, mediaType, normalizedTitle, releaseYear])
  @@index([provider, ratingType, ratingValue])
}

model MediaTitleProviderLink {
  id              String                       @id @default(cuid())
  mediaTitleId    String
  providerTitleId String                       @unique
  mediaType       MediaType
  confidence      Float
  source          MediaTitleProviderLinkSource
  confirmedAt     DateTime
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  mediaTitle    MediaTitle    @relation(fields: [mediaTitleId, mediaType], references: [id, mediaType], onDelete: Cascade)
  providerTitle ProviderTitle @relation(fields: [providerTitleId, mediaType], references: [id, mediaType], onDelete: Cascade)

  @@unique([mediaTitleId, providerTitleId])
  @@unique([providerTitleId, mediaType])
  @@index([mediaTitleId])
}

model ParsedReleaseMatch {
  id                String                   @id @default(cuid())
  tenantId          String
  parsedReleaseId   String
  mediaTitleId      String?
  providerTitleId   String?
  mediaProviderIdentityId String?
  providerMediaMetadataId String?
  mediaType         MediaType?
  status            ParsedReleaseMatchStatus
  source            ParsedReleaseMatchSource
  confidence        Float?
  reason            String?
  matchedAt         DateTime?
  rejectedAt        DateTime?
  replacedByMatchId String?
  invalidatedAt     DateTime?
  staleReason       String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parsedRelease   ParsedRelease        @relation(fields: [parsedReleaseId, tenantId], references: [id, tenantId], onDelete: Cascade)
  mediaTitle      MediaTitle?          @relation(fields: [mediaTitleId], references: [id], onDelete: Restrict)
  providerTitle   ProviderTitle?       @relation(fields: [providerTitleId], references: [id], onDelete: Restrict)
  mediaProviderIdentity MediaProviderIdentity? @relation(fields: [mediaProviderIdentityId], references: [id], onDelete: Restrict)
  providerMediaMetadata ProviderMediaMetadata? @relation(fields: [providerMediaMetadataId], references: [id], onDelete: Restrict)
  replacedByMatch ParsedReleaseMatch?  @relation("ParsedReleaseMatchReplacement", fields: [replacedByMatchId], references: [id])
  replaces        ParsedReleaseMatch[] @relation("ParsedReleaseMatchReplacement")

  @@unique([id, tenantId])
  @@index([tenantId, parsedReleaseId, status, invalidatedAt])
  @@index([tenantId, mediaTitleId, status])
  @@index([tenantId, providerTitleId])
  @@index([tenantId, mediaProviderIdentityId])
  @@index([tenantId, providerMediaMetadataId])
}

model Downloader {
  id                String         @id @default(cuid())
  tenantId          String
  createdByUserId   String
  name              String
  type              DownloaderType
  baseUrl           String
  username          String?
  encryptedPassword String?
  defaultSavePath   String?
  category          String?
  tags              String[]
  enabled           Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy         User           @relation("DownloaderCreator", fields: [createdByUserId], references: [id])
  subscriptions     Subscription[]
  jobs              DownloadJob[]

  @@unique([id, tenantId])
  @@index([tenantId, enabled])
}

model Subscription {
  id              String                      @id @default(cuid())
  tenantId        String
  createdByUserId String
  downloaderId    String?
  mediaTitleId    String?
  title           String
  autoDownload    Boolean                     @default(true)
  enabled         Boolean                     @default(true)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  tenant          Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User                        @relation("SubscriptionCreator", fields: [createdByUserId], references: [id])
  downloader      Downloader?                 @relation(fields: [downloaderId, tenantId], references: [id, tenantId], onDelete: Restrict)
  mediaTitle      MediaTitle?                 @relation(fields: [mediaTitleId], references: [id], onDelete: Restrict)
  rule            SubscriptionRule?
  decisions       SubscriptionMatchDecision[]
  jobs            DownloadJob[]

  @@unique([id, tenantId])
  @@index([tenantId, createdByUserId])
  @@index([tenantId, enabled])
  @@index([tenantId, mediaTitleId])
}

model SubscriptionRule {
  id                   String       @id @default(cuid())
  tenantId             String
  subscriptionId       String
  mediaType            MediaType?
  provider             String?
  providerEntityType   String?
  providerId           String?
  imdbId               String?
  doubanId             String?
  titleRegex           String?
  includeRegex         String?
  excludeRegex         String?
  minResolution        Int?
  maxResolution        Int?
  sources              String[]
  codecs               String[]
  audio                String[]
  releaseGroupsInclude String[]
  releaseGroupsExclude String[]
  minSizeBytes         BigInt?
  maxSizeBytes         BigInt?
  season               Int?
  episodeStart         Int?
  episodeEnd           Int?
  criteriaJson         Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription         Subscription @relation(fields: [subscriptionId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([subscriptionId, tenantId])
  @@unique([id, tenantId])
  @@index([tenantId, subscriptionId])
  @@index([tenantId, provider, providerEntityType, providerId])
  @@index([tenantId, provider, providerId])
  @@index([tenantId, imdbId])
  @@index([tenantId, doubanId])
}

model SubscriptionMatchDecision {
  id             String       @id @default(cuid())
  tenantId       String
  subscriptionId String
  itemId         String
  accepted       Boolean
  reason         String
  ruleSnapshot   Json?
  createdAt      DateTime     @default(now())
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription   Subscription @relation(fields: [subscriptionId, tenantId], references: [id, tenantId], onDelete: Cascade)
  item           RssItem      @relation(fields: [itemId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([id, tenantId])
  @@index([tenantId, subscriptionId, createdAt])
  @@index([tenantId, itemId])
  @@index([tenantId, accepted])
}

model DownloadJob {
  id              String         @id @default(cuid())
  tenantId        String
  itemId          String
  subscriptionId  String?
  downloaderId    String
  createdByUserId String?
  source          DownloadSource
  status          DownloadStatus @default(QUEUED)
  dedupeKey       String?
  infoHash        String?
  clientHash      String?
  attemptCount    Int            @default(0)
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  error           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item            RssItem        @relation(fields: [itemId, tenantId], references: [id, tenantId], onDelete: Cascade)
  subscription    Subscription?  @relation(fields: [subscriptionId, tenantId], references: [id, tenantId], onDelete: Restrict)
  downloader      Downloader     @relation(fields: [downloaderId, tenantId], references: [id, tenantId], onDelete: Cascade)
  createdBy       User?          @relation("DownloadJobCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([id, tenantId])
  @@unique([tenantId, dedupeKey])
  @@index([tenantId, status])
  @@index([tenantId, downloaderId])
  @@index([tenantId, subscriptionId])
  @@index([tenantId, infoHash])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([id, tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
}
