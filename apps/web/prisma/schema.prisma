generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

enum MediaKind {
  MOVIE
  TV
  UNKNOWN
}

enum ParseStatus {
  PENDING
  PARSED
  FAILED
}

enum MatchStatus {
  UNMATCHED
  CANDIDATE
  MATCHED
  REJECTED
}

enum DownloaderType {
  QBITTORRENT
  TRANSMISSION
}

enum DownloadStatus {
  QUEUED
  SENT
  DOWNLOADING
  COMPLETE
  FAILED
  SKIPPED
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  role         UserRole       @default(VIEWER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  feeds        RssFeed[]
  downloaders  Downloader[]
  subscriptions Subscription[]
  audits       AuditLog[]
}

model RssFeed {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  encryptedUrl        String    @db.Text
  pollIntervalSeconds Int       @default(300)
  enabled             Boolean   @default(true)
  lastPolledAt         DateTime?
  lastError            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items               RssItem[]

  @@index([userId])
  @@index([enabled])
}

model RssItem {
  id                  String          @id @default(cuid())
  feedId              String
  guid                String?
  linkHash            String
  rawTitle            String
  encryptedTorrentUrl String          @db.Text
  publishDate         DateTime?
  sizeBytes           BigInt?
  rawJson             Json
  parseStatus         ParseStatus     @default(PENDING)
  parseConfidence     Float           @default(0)
  firstSeenAt          DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  feed                RssFeed         @relation(fields: [feedId], references: [id], onDelete: Cascade)
  parsedRelease       ParsedRelease?
  mediaMatch          MediaMatch?
  downloadJobs        DownloadJob[]

  @@unique([feedId, linkHash])
  @@index([firstSeenAt])
  @@index([parseStatus])
}

model ParsedRelease {
  id           String    @id @default(cuid())
  itemId       String    @unique
  title        String
  year         Int?
  kind         MediaKind @default(UNKNOWN)
  season       Int?
  episode      Int?
  episodeEnd   Int?
  quality      String?
  source       String?
  codec        String?
  audio        String?
  releaseGroup String?
  confidence   Float     @default(0)
  raw          Json
  item         RssItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model MediaMatch {
  id            String      @id @default(cuid())
  itemId        String      @unique
  provider      String
  providerId    String
  kind          MediaKind
  title         String
  originalTitle String?
  year          Int?
  posterPath    String?
  backdropPath  String?
  overview      String?
  score         Float
  status        MatchStatus @default(CANDIDATE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  item          RssItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([provider, providerId])
  @@index([status])
}

model Downloader {
  id                String          @id @default(cuid())
  userId            String
  name              String
  type              DownloaderType
  baseUrl           String
  username          String?
  encryptedPassword String?
  defaultSavePath   String?
  category          String?
  tags              String?
  enabled           Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptions     Subscription[]
  jobs              DownloadJob[]

  @@index([userId])
}

model Subscription {
  id              String       @id @default(cuid())
  userId          String
  downloaderId    String?
  mediaProvider   String
  mediaProviderId String
  mediaKind       MediaKind
  title           String
  year            Int?
  includeRegex    String?
  excludeRegex    String?
  minQuality      String?
  season          Int?
  episodeStart    Int?
  episodeEnd      Int?
  autoDownload    Boolean      @default(true)
  enabled         Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  downloader      Downloader?  @relation(fields: [downloaderId], references: [id], onDelete: SetNull)
  jobs            DownloadJob[]

  @@index([userId])
  @@index([mediaProvider, mediaProviderId])
  @@index([enabled])
}

model DownloadJob {
  id             String         @id @default(cuid())
  itemId         String
  subscriptionId String?
  downloaderId   String
  status         DownloadStatus @default(QUEUED)
  clientHash     String?
  error          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  item           RssItem        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  subscription   Subscription?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  downloader     Downloader     @relation(fields: [downloaderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([downloaderId])
  @@index([subscriptionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}
