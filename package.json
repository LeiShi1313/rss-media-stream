{
  "name": "rss-media-stream-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @rss-media/web",
    "build": "npm run build -w @rss-media/shared && npm run build -w @rss-media/web",
    "start": "npm run start -w @rss-media/web",
    "worker": "npm run worker -w @rss-media/web",
    "test": "npm run build -w @rss-media/shared && npm run test -w @rss-media/shared && npm run test -w @rss-media/web",
    "prisma:generate": "prisma generate --schema apps/web/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema apps/web/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
